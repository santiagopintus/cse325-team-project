@implements IDisposable
@inject ToastService ToastService

<div class="toast-stack" aria-live="polite">
    @foreach (var toast in toasts)
    {
        <div class="toast-item toast-@toast.Level.ToString().ToLowerInvariant()" @key="toast.Id">
            <span>@toast.Text</span>
            <button type="button" class="toast-close" @onclick="() => Remove(toast.Id)" aria-label="Dismiss">&#10005;</button>
        </div>
    }
</div>

@code {
    private readonly List<ToastMessage> toasts = new();

    protected override void OnInitialized()
    {
        ToastService.OnShow += HandleShow;
    }

    private void HandleShow(ToastMessage toast)
    {
        toasts.Add(toast);
        _ = InvokeAsync(StateHasChanged);
        _ = AutoDismiss(toast.Id);
    }

    private async Task AutoDismiss(Guid id)
    {
        await Task.Delay(5000);
        Remove(id);
    }

    private void Remove(Guid id)
    {
        if (toasts.RemoveAll(t => t.Id == id) > 0)
        {
            _ = InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        ToastService.OnShow -= HandleShow;
    }
}
