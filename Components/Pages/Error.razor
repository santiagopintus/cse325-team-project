@page "/Error"
@using System.Diagnostics

<PageTitle>Something went wrong</PageTitle>

<div class="page-error">
    <h1>Something went wrong</h1>
    <p>We hit a snag processing your request. Try again in a moment &mdash; if it keeps happening, let us know.</p>

    @if (ShowRequestId)
    {
        <p class="text-muted small">Reference: <code>@RequestId</code></p>
    }

    <div class="page-error-actions">
        <a class="btn btn-primary btn-sm" href="/">Go home</a>
    </div>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
