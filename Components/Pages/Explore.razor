@page "/"
@using Microsoft.EntityFrameworkCore
@using QuestLog.Data
@using QuestLog.Models
@using QuestLog.Services.Rawg
@inject RawgApiService RawgApi
@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Explore Games</PageTitle>

<h3>Explore Games</h3>

@if (isSearching)
{
    <p>Searching...</p>
}
else if (games.Count > 0)
{
    <div class="game-grid">
        @foreach (var game in games)
        {
            <GameCard Title="@game.Name"
                      ImageUrl="@game.Background_Image"
                      Platform="@string.Join(", ", game.Platforms.Select(p => p.Platform.Name))">
                <AuthorizeView>
                    <Authorized>
                        @if (addedRawgIds.Contains(game.Id))
                        {
                            <button class="btn btn-secondary btn-sm" disabled>Added</button>
                        }
                        else
                        {
                            <button class="btn btn-primary btn-sm" @onclick="() => AddToShelf(game)">Add to Shelf</button>
                        }
                    </Authorized>
                    <NotAuthorized>
                        <a href="Account/Login" class="btn btn-outline-secondary btn-sm">Log in to Add</a>
                    </NotAuthorized>
                </AuthorizeView>
            </GameCard>
        }
    </div>
}
else if (hasSearched && !searchFailed)
{
    <p>No games found for "@searchQuery".</p>
}

@code {
    [SupplyParameterFromQuery(Name = "q")]
    public string? QueryParam { get; set; }

    private string searchQuery = "";
    private string? lastQuery;
    private List<RawgGameDto> games = new();
    private HashSet<int> addedRawgIds = new();
    private bool isSearching;
    private bool hasSearched;
    private bool searchFailed;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(QueryParam))
        {
            await LoadDefaultGames();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(QueryParam) && QueryParam != lastQuery)
        {
            lastQuery = QueryParam;
            searchQuery = QueryParam;
            await Search();
        }
    }

    private async Task LoadDefaultGames() =>
        await FetchGames(() => RawgApi.GetPopularGamesAsync(), "Couldn't load games right now. Please try again.");

    private async Task Search()
    {
        await FetchGames(() => RawgApi.SearchGamesAsync(searchQuery), "Couldn't search games right now. Please try again.");
        hasSearched = true;
    }

    private async Task FetchGames(Func<Task<List<RawgGameDto>>> fetch, string errorMessage)
    {
        isSearching = true;
        searchFailed = false;

        try
        {
            games = await fetch();
        }
        catch (Exception)
        {
            games = new();
            searchFailed = true;
            Toast.Show(errorMessage, ToastLevel.Error);
        }

        isSearching = false;

        if (!searchFailed && userId != null && games.Count > 0)
        {
            var rawgIds = games.Select(g => g.Id).ToList();
            addedRawgIds = DbContext.UserGames
                .Where(g => g.UserId == userId && rawgIds.Contains(g.RawgId))
                .Select(g => g.RawgId)
                .ToHashSet();
        }
    }

    private async Task AddToShelf(RawgGameDto rawgGame)
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (currentUserId == null) return;

        var exists = DbContext.UserGames.Any(g => g.UserId == currentUserId && g.RawgId == rawgGame.Id);
        if (exists) return;

        var newUserGame = new UserGame
        {
            UserId = currentUserId,
            RawgId = rawgGame.Id,
            Title = rawgGame.Name,
            CoverArtUrl = rawgGame.Background_Image,
            Platform = rawgGame.Platforms.FirstOrDefault()?.Platform.Name ?? "Unknown",
            Status = PlayStatus.Backlog
        };

        try
        {
            DbContext.UserGames.Add(newUserGame);
            await DbContext.SaveChangesAsync();
            addedRawgIds.Add(rawgGame.Id);
        }
        catch (Exception)
        {
            Toast.Show("Couldn't add that game to your shelf. Please try again.", ToastLevel.Error);
        }
    }
}
